# μ (mu) — OpenAI 兼容端点配置
# 选一个 provider，填好三项；代码通过 MU_MODEL/MU_BASE_URL/MU_API_KEY 读取。

# 百炼 (Alibaba DashScope, OpenAI 兼容)
MU_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
MU_MODEL=qwen-max
MU_API_KEY=sk-xxxxxxxx

